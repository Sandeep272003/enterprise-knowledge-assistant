# ══════════════════════════════════════════════════════════════════
# Enterprise Knowledge Assistant - Environment Configuration
# ══════════════════════════════════════════════════════════════════
# Copy this file as .env and fill in your values.
# NEVER commit your .env file to version control.
# ══════════════════════════════════════════════════════════════════

# ── Groq API ───────────────────────────────────────────────────
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# ── Server ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Model ──────────────────────────────────────────────
# Only one LLM model needed: llama-3.3-70b-versatile
# (Embeddings use local hashing-trick — zero API calls)
CHAT_MODEL=llama-3.3-70b-versatile
EMBEDDING_DIMENSION=384

# ── Chunking ───────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# ── Advanced Features ──────────────────────────────────────────
# Enable/disable advanced operations (true/false)
ENABLE_QUERY_CLASSIFICATION=true
ENABLE_ANSWER_VERIFICATION=true
ENABLE_RELATED_QUESTIONS=true
ENABLE_STREAMING=true
ENABLE_SOURCE_FILTER=true
ENABLE_QUERY_DECOMPOSITION=true

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_MAX=100